-- ========== Вкладка "БЛОКИ" ==========
local BlocksTab = Window:CreateTab("🧱 Блоки", 4483362458) -- иконка
local BlocksSection = BlocksTab:CreateSection("Управление блоками")

-- Переменная для отслеживания бесконечных блоков
local infiniteBlocksEnabled = false
local blockMonitor

-- Функция обновления отображения блоков
local function updateBlockDisplay()
    local player = game.Players.LocalPlayer
    local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
    if blocks then
        BlocksSection:Set("BlocksCount", "📦 Блоков: " .. tostring(blocks.Value))
    end
end

-- Тоггл "Бесконечные блоки"
BlocksTab:CreateToggle({
    Name = "♾️ Бесконечные блоки",
    CurrentValue = false,
    Flag = "InfiniteBlocks",
    Callback = function(Value)
        infiniteBlocksEnabled = Value
        local player = game.Players.LocalPlayer
        if Value then
            -- Запускаем цикл, который каждые 0.1 сек ставит 99999 блоков
            blockMonitor = game:GetService("RunService").Heartbeat:Connect(function()
                local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
                if blocks then
                    blocks.Value = 99999
                end
            end)
            -- Также сразу выставляем
            local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
            if blocks then blocks.Value = 99999 end
            Rayfield:Notify({
                Title = "♾️ Бесконечные блоки",
                Content = "Включены! Теперь блоки уходят в минус, если кончатся.",
                Duration = 3,
                Image = 4483362458,
            })
        else
            if blockMonitor then blockMonitor:Disconnect() end
            Rayfield:Notify({
                Title = "♾️ Бесконечные блоки",
                Content = "Отключены.",
                Duration = 2,
                Image = 4483362458,
            })
        end
    end
})

-- Кнопка "Добавить 1000 блоков"
BlocksTab:CreateButton({
    Name = "➕ +1000 блоков",
    Callback = function()
        local player = game.Players.LocalPlayer
        local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
        if blocks then
            blocks.Value = blocks.Value + 1000
            updateBlockDisplay()
            Rayfield:Notify({
                Title = "✅ Блоки добавлены",
                Content = "Теперь у вас " .. blocks.Value .. " блоков.",
                Duration = 2,
            })
        else
            Rayfield:Notify({
                Title = "❌ Ошибка",
                Content = "Не найден leaderstats.Blocks",
                Duration = 2,
            })
        end
    end
})

-- Отображение количества блоков (обновляется)
BlocksTab:CreateLabel("📦 Блоков: 0", "BlocksCount") -- флаг для обновления

-- Запускаем обновление каждую секунду
game:GetService("RunService").Heartbeat:Connect(function()
    updateBlockDisplay()
end)

