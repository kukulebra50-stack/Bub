                if not infiniteBlocksEnabled then
                    infiniteBlocksEnabled = true
                    blockMonitor = game:GetService("RunService").Heartbeat:Connect(function()
                        local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
                        if blocks then
                            blocks.Value = 99999
                        end
                    end)
                    local blocks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Blocks")
                    if blocks then blocks.Value = 99999 end
                    Rayfield:Notify({
                        Title = "♾️ Бесконечные блоки",
                        Content = "Включены (из автобилда)",
                        Duration = 2,
                    })
                end
            else
                -- Отключаем, только если эта функция активна, но мы не будем отключать, если включена из другой вкладки
                -- Просто выключим этот тоггл? Лучше просто выключить основную
                if infiniteBlocksEnabled then
                    infiniteBlocksEnabled = false
                    if blockMonitor then blockMonitor:Disconnect() end
                    Rayfield:Notify({
                        Title = "♾️ Бесконечные блоки",
                        Content = "Отключены (из автобилда)",
                        Duration = 2,
                    })
                end
            end
        end
    end
})

